    "import matplotlib.pyplot as plt\n",
    "\n",
    "bulan = ['Jan', 'Feb', 'Mar', 'Apr']\n",
    "subs = [100, 200, 400, 600]\n",
    "\n",
    "plt.plot(bulan, subs)\n",
    "\n",
    "plt.title(\"Pertumbuhan Subscribers\")\n",
    "plt.xlabel(\"Bulan\")\n",
    "plt.ylabel(\"Jumlah Subscribers\")\n",
    "\n",
    "plt.show()"
   ]
  }
